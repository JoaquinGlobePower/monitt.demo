# Clerk — autenticación (Google, email/contraseña, recuperación de contraseña)
# Consíguela en: https://dashboard.clerk.com  →  tu app  →  API Keys  →  "Publishable key"
# Es pública (segura en el frontend). Copia este archivo a .env.local y pega tu clave.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Solo para el script de cuentas de prueba (npm run seed:users). NO la usa la app (es server-side).
# Clerk → API Keys → "Secret keys" (empieza con sk_). Nunca la subas ni la expongas en el frontend.
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
